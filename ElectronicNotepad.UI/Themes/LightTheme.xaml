<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="WindowBgColor">#F7F9F7</Color>
    <Color x:Key="HeaderColor">#2F4F4F</Color>
    <Color x:Key="SubHeaderColor">#4A6A4A</Color>
    <Color x:Key="ButtonBgColor">#A8D5BA</Color>
    <Color x:Key="ButtonFgColor">#2F4F4F</Color>
    <Color x:Key="CardBgColor">#FFFFFF</Color>
    <Color x:Key="BorderColor">#E0E0E0</Color>

    <SolidColorBrush x:Key="WindowBgBrush" Color="{StaticResource WindowBgColor}"/>
    <SolidColorBrush x:Key="HeaderBrush" Color="{StaticResource HeaderColor}"/>
    <SolidColorBrush x:Key="SubHeaderBrush" Color="{StaticResource SubHeaderColor}"/>
    <SolidColorBrush x:Key="ButtonBgBrush" Color="{StaticResource ButtonBgColor}"/>
    <SolidColorBrush x:Key="ButtonFgBrush" Color="{StaticResource ButtonFgColor}"/>
    <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBgColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
</ResourceDictionary>