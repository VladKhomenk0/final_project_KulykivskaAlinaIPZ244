<Window x:Class="ElectronicNotepad.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пам'ятайка" Height="960" Width="540" 
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBgBrush}">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ButtonFgBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="15"/>
                </Style>
            </Style.Resources>
        </Style>

        <DataTemplate x:Key="NoteItemTemplate">
            <Grid Margin="0,4">
                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="15" Padding="20,15" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource HeaderBrush}"/>
                            <TextBlock Text="{Binding Content}" FontSize="14" Foreground="{DynamicResource SubHeaderBrush}" MaxHeight="40" TextTrimming="CharacterEllipsis" Margin="0,5,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="📌" 
                                Command="{Binding DataContext.TogglePinCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                CommandParameter="{Binding}"
                                Background="Transparent" Padding="5" VerticalAlignment="Top" FontSize="16">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Opacity" Value="0.3"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.8"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </DataTemplate>
    </Window.Resources>
    
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,30">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="Пам'ятайка" FontSize="42" FontWeight="Bold" 
                           Foreground="{DynamicResource HeaderBrush}" HorizontalAlignment="Center"/>
                <TextBlock Text="Електронний записник з нагадуваннями" FontSize="16" 
                           Foreground="{DynamicResource SubHeaderBrush}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
            <Button Content="{Binding ThemeIcon}" ToolTip="{Binding ThemeName}" 
                    HorizontalAlignment="Right" VerticalAlignment="Top" 
                    Width="50" Height="50" Command="{Binding ChangeThemeCommand}"
                    Background="{DynamicResource ButtonBgBrush}" FontSize="20">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="25"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>

        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Content="+ Нова нотатка" Click="AddNote_Click" 
                        Height="60" FontSize="18" Background="#C1E1C1"/>
                <Button Grid.Column="1" Content="↶" Command="{Binding UndoCommand}" 
                        Width="50" Height="60" Margin="12,0,0,0" ToolTip="Відмінити дію" Background="#B0B0B0" FontSize="20"/>
                <Button Grid.Column="2" Content="↷" Command="{Binding RedoCommand}" 
                        Width="50" Height="60" Margin="8,0,0,0" ToolTip="Повторити дію" Background="#B0B0B0" FontSize="20"/>
            </Grid>
            
            <GroupBox Header="Пошук та фільтрація" Padding="15" 
                      BorderBrush="{DynamicResource SubHeaderBrush}" Foreground="{DynamicResource SubHeaderBrush}">
                <StackPanel>
                    <TextBlock Text="Пошук за текстом:" FontSize="14" Margin="0,0,0,5" Foreground="{DynamicResource SubHeaderBrush}"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                             Height="40" Margin="0,0,0,15" Padding="12,8" 
                             VerticalContentAlignment="Center" FontSize="14"
                             Background="{DynamicResource CardBgBrush}" Foreground="{DynamicResource HeaderBrush}"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Категорія:" FontSize="14" Margin="0,0,0,5" Foreground="{DynamicResource SubHeaderBrush}"/>
                            <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategoryFilter}" 
                                      DisplayMemberPath="Name" Height="35" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="Пріоритет:" FontSize="14" Margin="0,0,0,5" Foreground="{DynamicResource SubHeaderBrush}"/>
                            <ComboBox ItemsSource="{Binding PriorityLevels}" 
                                      SelectedItem="{Binding SelectedPriorityFilter}" 
                                      Height="35" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <ListBox Grid.Row="2" ItemsSource="{Binding Notes}" 
                 ItemTemplate="{StaticResource NoteItemTemplate}"
                 x:Name="NotesList" MouseDoubleClick="NotesList_MouseDoubleClick"
                 Background="Transparent" BorderThickness="0"
                 Margin="0,0,0,25" HorizontalContentAlignment="Stretch">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,10"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Style.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                    </Style.Resources>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Змінити" Click="EditNote_Click" 
                    Height="50" FontSize="14" Margin="0,0,5,0" Background="#D0E8D0"/>
            <Button Grid.Column="1" Content="Аналітика" Click="ShowAnalytics_Click" 
                    Height="50" FontSize="14" Margin="5,0,5,0" Background="#D0E0F0"/>
            <Button Grid.Column="2" Content="Бекап" Click="Backup_Click" 
                    Height="50" FontSize="14" Margin="5,0,5,0" Background="#F0F0D0"/>
            <Button Grid.Column="3" Content="Видалити" Click="DeleteNote_Click" 
                    Height="50" FontSize="14" Margin="5,0,0,0" Background="#F1D1D1"/>
        </Grid>
    </Grid>
</Window>